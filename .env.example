# ─── JDFit — Root .env for Docker Compose ───────────────────────────────────
# Copy this file to .env in the project root and fill in your values.
# This file is READ by docker-compose.yml for ${VAR} substitution.

# Required: Your OpenRouter API key
OPENROUTER_API_KEY=your-openrouter-api-key-here

# Required: Strong random secrets (generate with: openssl rand -hex 32)
JWT_SECRET=change-me-to-a-strong-random-secret
JWT_REFRESH_SECRET=change-me-to-another-strong-random-secret
